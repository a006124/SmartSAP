<UserControl x:Class="SmartSAP.Views.Modules.Module07View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Workflow Steps -->
            <RowDefinition Height="*"/>    <!-- Logs -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,5">
            <Button Command="{Binding GoBackCommand}" Background="Transparent" BorderThickness="0" Margin="0,0,15,0" DockPanel.Dock="Left">
                <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{StaticResource TextPrimaryBrush}"/>
            </Button>
            <StackPanel>
                <TextBlock Text="{Binding ModuleTitle}" Style="{StaticResource Header1}"/>
                <TextBlock Text="Exécutez les étapes ci-dessous pour lancer la création des équipements dans SAP." Style="{StaticResource SubHeader}"/>
            </StackPanel>
        </DockPanel>



        <!-- Workflow Steps -->
        <ScrollViewer Grid.Row="1" Margin="0,10,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Steps}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                            <Button Command="{Binding ActionCommand}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Button.Template>
                                <Border Width="200" Height="220" Style="{StaticResource ModuleCard}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Border Grid.Row="0" Width="40" Height="40" CornerRadius="8"
                                                Background="{StaticResource BluePastelBrush}"
                                                HorizontalAlignment="Left" Margin="0,0,0,15">
                                            <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"
                                                       FontSize="18" Foreground="{StaticResource AccentBlueBrush}"/>
                                        </Border>

                                        <StackPanel Grid.Row="1">
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5" TextWrapping="Wrap"/>
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap">
                                                <Run Text="{Binding Description}"/>
                                                <Hyperlink Command="{Binding LinkCommand}" Foreground="{StaticResource AccentBlueBrush}" TextDecorations="None">
                                                    <TextBlock Text="{Binding LinkText}" VerticalAlignment="Center"/>
                                                </Hyperlink>
                                            </TextBlock>
                                        </StackPanel>

                                        <Border Grid.Row="2" Background="{StaticResource WindowBackgroundBrush}"
                                                CornerRadius="4" Padding="5" HorizontalAlignment="Stretch">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ResultState}" Value="Processing">
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ResultState}" Value="Success">
                                                            <Setter Property="BorderBrush" Value="{StaticResource ConsoleSuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ResultState}" Value="Error">
                                                            <Setter Property="BorderBrush" Value="{StaticResource ConsoleErrorBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}" HorizontalAlignment="Center"
                                                       FontSize="10" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ResultState}" Value="Processing">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ResultState}" Value="Success">
                                                                <Setter Property="Foreground" Value="{StaticResource ConsoleSuccessBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ResultState}" Value="Error">
                                                                <Setter Property="Foreground" Value="{StaticResource ConsoleErrorBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Button>
                            <TextBlock Style="{StaticResource ConnectorArrow}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Log Section -->
        <Border Grid.Row="2" Margin="0,20,0,0" Background="{StaticResource ConsoleBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1,1,1,0" CornerRadius="8,8,0,0"
                AllowDrop="True" Drop="LogSection_Drop" DragEnter="LogSection_DragEnter" DragOver="LogSection_DragEnter">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#2D2D2D"
                        CornerRadius="8,8,0,0" Padding="10">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" 
                                       Foreground="#CCCCCC" Margin="0,0,8,0" FontSize="12"/>
                            <TextBlock Text="TERMINAL - EXECUTION LOGS" VerticalAlignment="Center"
                                       FontWeight="Bold" FontSize="10" Foreground="#CCCCCC"/>
                        </StackPanel>

                        <Button HorizontalAlignment="Right" Command="{Binding ClearLogsCommand}"
                                Background="Transparent" BorderThickness="0" Padding="5,0"
                                Cursor="Hand" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="12" 
                                           Foreground="#CCCCCC" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="VIDER" FontSize="9" Foreground="#CCCCCC" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" Margin="10" HorizontalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Logs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock FontFamily="Consolas" FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource ConsoleDefaultTextBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="INFO">
                                                        <Setter Property="Foreground" Value="{StaticResource ConsoleInfoBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="SUCCESS">
                                                        <Setter Property="Foreground" Value="{StaticResource ConsoleSuccessBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="ERROR">
                                                        <Setter Property="Foreground" Value="{StaticResource ConsoleErrorBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Type}" Value="WARNING">
                                                        <Setter Property="Foreground" Value="{StaticResource ConsoleWarningBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <Run Text="[" Foreground="{StaticResource ConsoleTimestampBrush}"/><Run Text="{Binding Timestamp, Mode=OneWay}" Foreground="{StaticResource ConsoleTimestampBrush}"/><Run Text="] " Foreground="{StaticResource ConsoleTimestampBrush}"/>
                                        <Run Text="{Binding Message, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Visibility="{Binding HasFile, Converter={StaticResource BoolToVis}}" Margin="2,0,0,0">
                                        <Hyperlink Command="{Binding OpenFileCommand}" TextDecorations="Underline" Foreground="{StaticResource AccentBlueBrush}" FontFamily="Consolas" FontSize="12">
                                            <Run Text="{Binding FileName, Mode=OneWay}"/>
                                        </Hyperlink>
                                    </TextBlock>
                                    <TextBlock Visibility="{Binding HasLink, Converter={StaticResource BoolToVis}}" Margin="2,0,0,0">
                                        <Hyperlink Command="{Binding LinkCommand}" TextDecorations="Underline" Foreground="{StaticResource AccentBlueBrush}" FontFamily="Consolas" FontSize="12">
                                            <Run Text="{Binding LinkText, Mode=OneWay}"/>
                                        </Hyperlink>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
