<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Neutral Colors -->
    <Color x:Key="WindowBackgroundColor">#F3F3F3</Color>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>
    
    <Color x:Key="CardBackgroundColor">#F0F4F8</Color>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    
    <Color x:Key="CardBorderColor">#64748B</Color>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>
    
    <Color x:Key="BorderColor">#E2E8F0</Color>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <Color x:Key="TextPrimaryColor">#1E293B</Color>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    
    <Color x:Key="TextSecondaryColor">#64748B</Color>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>

    <!-- Accent Colors -->
    <Color x:Key="AccentBlue">#3B82F6</Color>
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlue}"/>
    
    <Color x:Key="AccentGreen">#10B981</Color>
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreen}"/>
    
    <Color x:Key="AccentRed">#EF4444</Color>
    <SolidColorBrush x:Key="AccentRedBrush" Color="{StaticResource AccentRed}"/>
    
    <Color x:Key="AccentOrange">#F59E0B</Color>
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrange}"/>

    <!-- Pastels for Icons -->
    <SolidColorBrush x:Key="BluePastelBrush" Color="#DBEAFE"/>
    <SolidColorBrush x:Key="GreenPastelBrush" Color="#D1FAE5"/>
    <SolidColorBrush x:Key="RedPastelBrush" Color="#FEE2E2"/>
    <SolidColorBrush x:Key="OrangePastelBrush" Color="#FEF3C7"/>
    
    <Color x:Key="AccentPurple">#A855F7</Color>
    <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurple}"/>
    <SolidColorBrush x:Key="PurplePastelBrush" Color="#F3E8FF"/>

    <!-- Console / Terminal Colors -->
    <Color x:Key="ConsoleBackgroundColor">#1E1E1E</Color>
    <SolidColorBrush x:Key="ConsoleBackgroundBrush" Color="{StaticResource ConsoleBackgroundColor}"/>

    <Color x:Key="ConsoleDefaultTextColor">#D4D4D4</Color>
    <SolidColorBrush x:Key="ConsoleDefaultTextBrush" Color="{StaticResource ConsoleDefaultTextColor}"/>

    <Color x:Key="ConsoleTimestampColor">#858585</Color>
    <SolidColorBrush x:Key="ConsoleTimestampBrush" Color="{StaticResource ConsoleTimestampColor}"/>

    <Color x:Key="ConsoleInfoColor">#3794FF</Color>
    <SolidColorBrush x:Key="ConsoleInfoBrush" Color="{StaticResource ConsoleInfoColor}"/>

    <Color x:Key="ConsoleSuccessColor">#89D185</Color>
    <SolidColorBrush x:Key="ConsoleSuccessBrush" Color="{StaticResource ConsoleSuccessColor}"/>

    <Color x:Key="ConsoleWarningColor">#CCA700</Color>
    <SolidColorBrush x:Key="ConsoleWarningBrush" Color="{StaticResource ConsoleWarningColor}"/>

    <Color x:Key="ConsoleErrorColor">#F48771</Color>
    <SolidColorBrush x:Key="ConsoleErrorBrush" Color="{StaticResource ConsoleErrorColor}"/>

</ResourceDictionary>
