<Window x:Class="SmartSAP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SmartSAP.ViewModels"
        xmlns:views="clr-namespace:SmartSAP.Views"
        xmlns:vmmodules="clr-namespace:SmartSAP.ViewModels.Modules"
        xmlns:vmodules="clr-namespace:SmartSAP.Views.Modules"
        mc:Ignorable="d"
        Title="SmartSAP - Workflow Automation" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource WindowBackgroundBrush}">

    <Window.Resources>
        <!-- Mapping des ViewModels aux Views -->
        <DataTemplate DataType="{x:Type vm:LibraryViewModel}">
            <views:LibraryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmmodules:Module01ViewModel}">
            <vmodules:Module01View/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmmodules:Module02ViewModel}">
            <vmodules:Module02View/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmmodules:Module03ViewModel}">
            <vmodules:Module03View/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmmodules:Module04ViewModel}">
            <vmodules:Module04View/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmmodules:Module05ViewModel}">
            <vmodules:Module05View/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmmodules:Module06ViewModel}">
            <vmodules:Module06View/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmmodules:Module07ViewModel}">
            <vmodules:Module07View/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmmodules:Module08ViewModel}">
            <vmodules:Module08View/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmmodules:Module09ViewModel}">
            <vmodules:Module09View/>
        </DataTemplate>

        <!-- Style bouton navigation sidebar -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="Width" Value="72"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           Foreground="#4B5568"
                                           Text="{TemplateBinding Tag}"/>
                                <TextBlock Text="{TemplateBinding Content}"
                                           FontSize="11"
                                           FontFamily="Segoe UI"
                                           HorizontalAlignment="Center"
                                           Margin="0,5,0,0"
                                           Foreground="#4B5568"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DDE1E8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#CBD0D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Status Bar — Hauteur 28px (typique barre d'état compacte/titre) -->
        <StatusBar DockPanel.Dock="Bottom" Height="28" Padding="10,0"
                   Background="royalblue"
                   BorderBrush="{StaticResource BorderBrush}"
                   BorderThickness="0,1,0,0">
            <!-- Connection SAP -->
            <StatusBarItem Padding="0">
                <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                    <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="SAP Connection: ERP_PROD_100 (Active)"
                               FontSize="11" FontFamily="Segoe UI"
                               Foreground="white" VerticalAlignment="Center" Margin="0,0,0,1"/>
                </StackPanel>
            </StatusBarItem>
            
            <StatusBarItem Padding="0">
                <Separator Background="#D1D5DB" Margin="5,6,5,6"/>
            </StatusBarItem>
            
            <!-- Data Prep -->
            <StatusBarItem Padding="0">
                <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                    <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="white" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Data Prep: Excel Linked"
                               FontSize="11" FontFamily="Segoe UI"
                               Foreground="white" VerticalAlignment="Center" Margin="0,0,0,1"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- Layout Central -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#e5e5e5ff" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Navigation : Library + Logs en haut -->
                    <StackPanel Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Style="{StaticResource NavButton}" Content="Library" Tag="&#xE8A1;" Margin="0,4"/>
                        <Button Style="{StaticResource NavButton}" Content="Logs"    Tag="&#xE823;" Margin="0,4"/>
                    </StackPanel>

                    <!-- Settings en bas -->
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Separator Background="{StaticResource BorderBrush}" Margin="4,0,4,10" Height="1"/>
                        <Button Style="{StaticResource NavButton}" Content="Settings" Tag="&#xE713;" Margin="0,4"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Border Grid.Column="1" Background="{StaticResource WindowBackgroundBrush}">
                <ContentControl Content="{Binding CurrentViewModel}"/>
            </Border>

        </Grid>
    </DockPanel>
</Window>
